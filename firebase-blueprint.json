{
  "entities": {
    "Report": {
      "title": "Report",
      "description": "A report of administrative inaction or misconduct submitted by a citizen.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the report."
        },
        "category": {
          "type": "string",
          "description": "The category of the report (inaction, misconduct, other).",
          "enum": ["inaction", "misconduct", "other"]
        },
        "description": {
          "type": "string",
          "description": "The detailed description of the incident."
        },
        "location": {
          "type": "string",
          "description": "The location where the incident occurred."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date when the incident occurred."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who submitted the report."
        },
        "userEmail": {
          "type": "string",
          "format": "email",
          "description": "The email of the user who submitted the report."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the report was created."
        }
      },
      "required": ["title", "category", "description", "location", "date", "userId", "userEmail", "createdAt"]
    },
    "MisconductCase": {
      "title": "MisconductCase",
      "description": "An administrative misconduct or inaction case collected by AI.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the incident."
        },
        "description": {
          "type": "string",
          "description": "The summary of the incident."
        },
        "date": {
          "type": "string",
          "description": "The date of the incident."
        },
        "location": {
          "type": "string",
          "description": "The location of the incident."
        },
        "category": {
          "type": "string",
          "description": "The category of the misconduct (organizational, individual, other).",
          "enum": ["organizational", "individual", "other"]
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "uri": { "type": "string" }
            }
          }
        },
        "collectedBy": {
          "type": "string",
          "description": "The ID of the collector (AI or user)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["title", "description", "collectedBy", "createdAt"]
    },
    "TownEvaluation": {
      "title": "TownEvaluation",
      "description": "A citizen's evaluation of their town's human rights and livability.",
      "type": "object",
      "properties": {
        "townName": { "type": "string" },
        "transparency": { "type": "number" },
        "accountability": { "type": "number" },
        "inclusion": { "type": "number" },
        "safety": { "type": "number" },
        "humanRights": { "type": "number" },
        "comment": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["townName", "transparency", "accountability", "inclusion", "safety", "humanRights", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Collection of citizen reports."
    },
    "/misconduct_cases/{caseId}": {
      "schema": "MisconductCase",
      "description": "Collection of AI-collected misconduct cases."
    },
    "/town_evaluations/{evaluationId}": {
      "schema": "TownEvaluation",
      "description": "Collection of citizen town evaluations."
    }
  }
}
