rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Reports collection
    match /reports/{reportId} {
      // Anyone can read reports (for analysis)
      allow read: if true;
      
      // Only authenticated users can create reports
      allow create: if isAuthenticated() && 
        request.resource.data.keys().hasAll(['title', 'category', 'description', 'location', 'date', 'userId', 'userEmail', 'createdAt']) &&
        request.resource.data.userId == request.auth.uid;
        
      // No updates or deletes for now to maintain integrity of records
      allow update, delete: if false;
    }

    // Misconduct cases collection (AI collected)
    match /misconduct_cases/{caseId} {
      // Anyone can read the feed
      allow read: if true;
      
      // Only authenticated users or the server (AI) can create
      // Note: Server-side SDK bypasses rules, but we keep this for manual saves from UI
      allow create: if isAuthenticated() && 
        request.resource.data.keys().hasAll(['title', 'description', 'collectedBy', 'createdAt']);
        
      allow update, delete: if false;
    }

    // Town evaluations collection
    match /town_evaluations/{evaluationId} {
      // Anyone can read evaluations to see how their town is doing
      allow read: if true;
      
      // Only authenticated users can create evaluations
      allow create: if isAuthenticated() && 
        request.resource.data.keys().hasAll(['townName', 'transparency', 'accountability', 'inclusion', 'safety', 'humanRights', 'userId', 'createdAt']) &&
        request.resource.data.userId == request.auth.uid;
        
      allow update, delete: if false;
    }
  }
}
