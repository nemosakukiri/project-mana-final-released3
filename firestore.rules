rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Reports collection
    match /reports/{reportId} {
      // Anyone can read reports (for analysis)
      allow read: if true;
      
      // Only authenticated users can create reports
      allow create: if isAuthenticated() && 
        request.resource.data.keys().hasAll(['title', 'category', 'description', 'location', 'date', 'userId', 'userEmail', 'createdAt']) &&
        request.resource.data.userId == request.auth.uid;
        
      // No updates or deletes for now to maintain integrity of records
      allow update, delete: if false;
    }
  }
}
